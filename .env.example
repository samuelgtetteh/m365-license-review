# ---------------------------------------------------------------------------
# M365 License Review — environment configuration
# Copy this file to `.env` and fill in the values. `.env` is git-ignored.
# ---------------------------------------------------------------------------

# The Application (client) ID of the MSP's multi-tenant Azure AD app registration.
# This is ONE app in the MSP's own tenant, reused across all client tenants.
# See README.md §"Azure AD app registration" for how to create it.
AZURE_APP_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Authority. Use /organizations so ANY work/school tenant can sign in.
# Do NOT hard-code a specific tenant ID here.
AZURE_AUTHORITY=https://login.microsoftonline.com/organizations

# OAuth redirect URI registered on the app (Web platform).
# Must EXACTLY match what is configured in Azure. For the local container:
AZURE_REDIRECT_URI=http://localhost:8000/auth/callback

# Random secret used to sign the browser session cookie.
# OPTIONAL: if left as-is (or unset), the tool auto-generates one on first start
# and persists it to data/.session_secret. Only set this if you want a fixed value.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=change-me-to-a-long-random-string

# Where generated reports are written (inside the container this is a mounted volume).
OUTPUT_DIR=./reports

# OPTIONAL: online rate card. If set, prices are fetched from this URL at runtime
# (JSON object {skuPartNumber: price}, JSON list of {sku, price}, or CSV with
# sku/price columns), cached to data/prices_cache.json, and fall back to the yaml
# when offline. Leave blank to use config/sku_prices.yaml only.
PRICE_SOURCE_URL=

# OPTIONAL: shown as "Prepared by ..." on the reports.
REPORT_COMPANY_NAME=

# Web server bind (inside the container).
HOST=0.0.0.0
PORT=8000
